{
  "autoCompactWindow": 210000,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_BUG_COMMAND": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MAX_MCP_OUTPUT_TOKENS": "60000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "60000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "60000",
    "BASH_MAX_OUTPUT_LENGTH": "30000",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "210000",
    "MCP_TIMEOUT": "10000",
    "MCP_TOOL_TIMEOUT": "10000",
    "CLAUDE_AFK_TIMEOUT_MS": "2000000000"
  },
  "permissions": {
    "allow": [
      "Bash(ls)",
