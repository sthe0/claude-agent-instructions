      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(less:*)",
      "Bash(more:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(jq:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(which:*)",
      "Bash(whoami)",
      "Bash(date:*)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(python3 -c \":*)",
      "Bash(python3 -m json.tool:*)",
      "Bash(arc info:*)",
      "Bash(arc status)",
      "Bash(arc status:*)",
      "Bash(arc log:*)",
      "Bash(arc diff:*)",
      "Bash(arc show:*)",
      "Bash(arc branch:*)",
      "Bash(arc grep:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
