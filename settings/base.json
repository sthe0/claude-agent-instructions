      "Bash(git config --get:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "WebSearch",
      "mcp__intrasearch__search",
      "mcp__intrasearch__semantic_code_search",
      "mcp__intrasearch__stsearch",
      "mcp__tracker__GetIssue",
      "mcp__tracker__GetIssueLinks",
      "mcp__wiki__GetPageDetails"
